 #include "impute.h"
 #include "nrutil.h"
 #include "error.h"
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+/* RFSRC_TRACE_UNO patches: opt-in trace of getCRPerformance inputs and
+   getCRConcordanceIndexIPCW_Fenwick results, gated on the
+   RFSRC_TRACE_UNO env var holding a writable file path. The fp is
+   re-opened on every call to track multi-fit sessions. */
+static FILE *rfsrc_uno_fp = NULL;
+static char  rfsrc_uno_path_seen[1024] = "";
+static void rfsrc_uno_maybe_open(void) {
+  const char *path = getenv("RFSRC_TRACE_UNO");
+  const char *effective = (path && path[0]) ? path : "";
+  if (strcmp(rfsrc_uno_path_seen, effective) == 0) return;
+  if (rfsrc_uno_fp) { fclose(rfsrc_uno_fp); rfsrc_uno_fp = NULL; }
+  strncpy(rfsrc_uno_path_seen, effective, sizeof(rfsrc_uno_path_seen) - 1);
+  rfsrc_uno_path_seen[sizeof(rfsrc_uno_path_seen) - 1] = '\0';
+  if (effective[0]) rfsrc_uno_fp = fopen(effective, "w");
+}
